{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "make",
            "args": [
                "CC=gcc-14",
                "debug"
            ],
            "windows": {
                "command": "C:/msys64/ucrt64/bin/mingw32-make.exe",
                "args": [
                    "debug"
                ]
            },
            "linux": {
                "command": "make",
                "args": [
                    "CC=gcc-14",
                    "debug"
                ]
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build Release",
            "type": "shell",
            "command": "make",
            "args": [
                "CC=gcc-14",
                "release"
            ],
            "windows": {
                "command": "C:/msys64/ucrt64/bin/mingw32-make.exe",
                "args": [
                    "release"
                ]
            },
            "linux": {
                "command": "make",
                "args": [
                    "CC=gcc-14",
                    "release"
                ]
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Run Exercise",
            "type": "shell",
            "command": "make",
            "args": [
                "CC=gcc-14",
                "run",
                "EX=${input:exercisePath}"
            ],
            "windows": {
                "command": "C:/msys64/ucrt64/bin/mingw32-make.exe",
                "args": [
                    "run",
                    "EX=${input:exercisePath}"
                ]
            },
            "linux": {
                "command": "make",
                "args": [
                    "CC=gcc-14",
                    "run",
                    "EX=${input:exercisePath}"
                ]
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "Build Debug",
            "problemMatcher": []
        },
        {
            "label": "Test Exercise",
            "type": "shell",
            "command": "make",
            "args": [
                "CC=gcc-14",
                "test",
                "EX=${input:exercisePath}"
            ],
            "windows": {
                "command": "C:/msys64/ucrt64/bin/mingw32-make.exe",
                "args": [
                    "test",
                    "EX=${input:exercisePath}"
                ]
            },
            "linux": {
                "command": "make",
                "args": [
                    "CC=gcc-14",
                    "test",
                    "EX=${input:exercisePath}"
                ]
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "Build Debug",
            "problemMatcher": []
        },
        {
            "label": "Test All",
            "type": "shell",
            "command": "make",
            "args": [
                "CC=gcc-14",
                "test-all"
            ],
            "windows": {
                "command": "C:/msys64/ucrt64/bin/mingw32-make.exe",
                "args": [
                    "test-all"
                ]
            },
            "linux": {
                "command": "make",
                "args": [
                    "CC=gcc-14",
                    "test-all"
                ]
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "Build Debug",
            "problemMatcher": []
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "make",
            "args": [
                "clean"
            ],
            "windows": {
                "command": "C:/msys64/ucrt64/bin/mingw32-make.exe",
                "args": [
                    "clean"
                ]
            },
            "linux": {
                "command": "make",
                "args": [
                    "clean"
                ]
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "exercisePath",
            "type": "promptString",
            "description": "Exercise path, e.g. chapter04/exercise09",
            "default": "chapter04/exercise09"
        }
    ]
}
