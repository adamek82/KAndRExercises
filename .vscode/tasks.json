{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/mingw32-make.exe",
            "args": [
                "debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build Release",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/mingw32-make.exe",
            "args": [
                "release"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Run Exercise",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/mingw32-make.exe",
            "args": [
                "run",
                "EX=${input:exercisePath}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "Build Debug",
            "problemMatcher": []
        },
        {
            "label": "Test Exercise",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/mingw32-make.exe",
            "args": [
                "test",
                "EX=${input:exercisePath}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "Build Debug",
            "problemMatcher": []
        },
        {
            "label": "Test All",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/mingw32-make.exe",
            "args": [
                "test-all"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "Build Debug",
            "problemMatcher": []
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/mingw32-make.exe",
            "args": [
                "clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "exercisePath",
            "type": "promptString",
            "description": "Exercise path, e.g. chapter01/exercise09",
            "default": "chapter01/exercise09"
        }
    ]
}
